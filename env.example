# Copy this file to .env and fill in values (never commit .env)
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Chat / rerank / query classifier LLM: openai | groq (Groq is OpenAI-compatible). Embeddings always use OpenAI above.
LLM_PROVIDER=openai
# When LLM_PROVIDER=groq:
# GROQ_API_KEY=your_groq_api_key
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_API_BASE=https://api.groq.com/openai/v1
# On-demand tier has strict TPM; if you see 413 / "Request too large", lower these (defaults are conservative):
# GROQ_MAX_CONTEXT_CHARS=16000
# GROQ_MAX_CHAT_HISTORY_CHARS=4000
# GROQ_MAX_CHARS_PER_CHUNK=3200
# Dashboard cost for Groq: defaults match ~llama-3.3-70b on-demand (see groq.com/pricing). Override if needed:
# GROQ_INPUT_USD_PER_1M=0.59
# GROQ_OUTPUT_USD_PER_1M=0.79

# Optional: cost logging (USD per 1M tokens) for OpenAI provider.
# OPENAI_INPUT_USD_PER_1M=
# OPENAI_OUTPUT_USD_PER_1M=

# Zilliz Configuration (Zilliz Cloud dashboard → cluster → Connect)
ZILLIZ_URI=https://your-cluster-id.serverless.your-region.cloud.zilliz.com
ZILLIZ_TOKEN=your_zilliz_api_token
ZILLIZ_COLLECTION_NAME=pdf_chatbot_collection
# Smaller batches + long HTTP write timeout reduce Zilliz Cloud "WriteTimeout" on large PDFs
ZILLIZ_INSERT_BATCH_SIZE=40
ZILLIZ_INSERT_TIMEOUT_SECONDS=300

# Application Configuration
UPLOAD_DIR=uploads
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
# Token-style text chunking (1 token ~ 4 chars): set CHUNK_TARGET_TOKENS=500, CHUNK_OVERLAP_PERCENT=12 to override
# CHUNK_TARGET_TOKENS=500
# CHUNK_OVERLAP_PERCENT=12
MAX_CHUNKS_TO_RETRIEVE=5
# Keep PDF and extracted images on disk after ingest (object storage)
STORE_PDF_AFTER_INGEST=true
STORE_EXTRACTED_IMAGES=true
# Vision captions for cropped PDF images at ingest (Groq default)
# ENABLE_VISION_IMAGE_CAPTIONS=true
# VISION_PROVIDER=groq
# GROQ_VISION_API_KEY=gsk_...   # optional; falls back to GROQ_API_KEY
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# MAX_VISION_CAPTIONS_PER_DOCUMENT=30
# Alternatives: VISION_PROVIDER=openai + VISION_CAPTION_MODEL=gpt-4o-mini
#               VISION_PROVIDER=gemini + GEMINI_API_KEY + GEMINI_VISION_MODEL
# Parent–child: PARENT_CONTEXT_MAX_PARENTS=8, PARENT_MEGA_CHILD_THRESHOLD=12
# If the user sends no file_ids: search all INGESTED documents. Set false to require explicit scope.
CHAT_AUTO_SCOPE_ALL_INGESTED=true

# PDF ingest tagging (technology / domain)
# DOCUMENT_CLASSIFY_MODE=heuristic   # heuristic | prompt — prompt = one LLM call first (ChatGPT-style), then fallback
# DOCUMENT_CLASSIFY_MIN_SCORE=10
# DOCUMENT_CLASSIFY_USE_LLM=false    # In heuristic mode only: LLM after keywords if still general
# DOCUMENT_CLASSIFY_LLM_MAX_CHARS=6000
# DOCUMENT_CLASSIFY_RESUME_THRESHOLD=9

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Supabase (REST API)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_anon_or_publishable_key
# Required for Storage uploads unless you add permissive Storage RLS policies:
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret
# Storage bucket for PDFs + extracted images (create in Dashboard → Storage → New bucket)
USE_SUPABASE_STORAGE=true
SUPABASE_STORAGE_BUCKET=rag-uploads
# Optional S3-compatible endpoint (AWS CLI / external tools; app uses supabase-py REST, not S3 SDK)
# SUPABASE_S3_ENDPOINT=https://your-project-ref.storage.supabase.co/storage/v1/s3
# Direct PostgreSQL - used only to create missing tables. Use either SUPABASE_DB_URL or the vars below.
# SUPABASE_DB_URL=postgresql://postgres:PASSWORD@db.xxxxx.supabase.co:5432/postgres
# Or (same as psycopg2.connect(user=..., password=..., host=..., port=..., dbname=...)):
# SUPABASE_DB_USER=postgres
# SUPABASE_DB_PASSWORD=your_password
# SUPABASE_DB_HOST=db.xxxxx.supabase.co
# SUPABASE_DB_PORT=5432
# SUPABASE_DB_NAME=postgres
